# ==============================================================================
# EASYDEV SUPPORT AI - MASTER ENVIRONMENT TEMPLATE (.env.example)
# ==============================================================================

# Core Application Settings
NODE_ENV=production
PORT=3100
APP_NAME=easydev-support-ai
APP_VERSION=1.0.0
API_PREFIX=/v1
# Public origin this API is reachable at - used to build absolute URLs for
# locally-stored files (e.g. widget attachments) returned to clients. Three
# separate names because the code reads three separate vars (different call
# sites, never consolidated) - keep all in sync by hand.
API_PUBLIC_URL=https://api.easydev.in
API_BASE_URL=https://api.easydev.in
PORTAL_URL=https://app.easydev.in
WIDGET_SURVEY_BASE_URL=https://widget.easydev.in

# CORS - origins allowed to call this API directly.
CORS_ALLOWED_ORIGINS=https://admin.easydev.in,https://app.easydev.in,https://widget.easydev.in,https://help.easydev.in

# Database Configuration (PostgreSQL 17)
DATABASE_URL=postgresql://support_ai_prod:prod_db_pass_extremely_secure_991823@postgres:5432/easydev_support_ai_prod?sslmode=disable
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=easydev_support_ai_prod
POSTGRES_USER=support_ai_prod
POSTGRES_PASSWORD=prod_db_pass_extremely_secure_991823

# Redis Cache & Queue Configuration (Redis 8)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_auth_pass_extremely_secure_991283
REDIS_DB=0

# IAM Service Integration
IAM_SERVICE_URL=https://iam.easydev.in
IAM_SERVICE_INTERNAL_URL=http://host.docker.internal:3001
# IAM service API key (usage-limit.service.ts) - separate from
# IAM_SERVICE_URL/IAM_SERVICE_INTERNAL_URL above.
IAM_SERVICE_API_KEY=iam_service_api_key_prod_991823

# AI Platform Integration
EASYDEV_AI_URL=https://ai.easydev.in
EASYDEV_AI_API_KEY=ai_platform_integration_secret_api_key_prod_991823

# Notification Service Integration
NOTIFICATION_SERVICE_URL=https://notification.easydev.in
NOTIFICATION_SERVICE_API_KEY=notification_service_secret_api_key_prod_991823

# Payment Service Integration
PAYMENT_SERVICE_URL=https://payment.easydev.in
PAYMENT_SERVICE_API_KEY=payment_service_secret_api_key_prod_991823
# Optional - IAM client_credentials for payment-microservice (preferred over
# the legacy API key above; payment-microservice's own source marks that
# path deprecated). Leave unset until this app is registered as an IAM
# application (POST /apps on the IAM service) and issued real credentials -
# PaymentClient transparently keeps using the API key above until then.
PAYMENT_IAM_CLIENT_ID=
PAYMENT_IAM_CLIENT_SECRET=
PAYMENT_IAM_SCOPES=payment:read payment:write

# File Upload Service Integration
FILE_UPLOAD_SERVICE_URL=https://upload.easydev.in
FILE_UPLOAD_SERVICE_HEALTH_URL=https://upload.easydev.in/health
# Shared gateway HMAC secret - must match the same value configured on the
# file-upload-service / payment-microservice side (PaymentClient signs
# outbound requests with this; their GatewayHmacGuard verifies with it).
FILE_UPLOAD_HMAC_SECRET=file_upload_hmac_verification_secret_key_prod_991823
# Separate auth header the code actually sends (file-upload.service.ts) -
# FILE_UPLOAD_HMAC_SECRET above is a different integration point's secret.
FILE_UPLOAD_SERVICE_API_KEY=file_upload_service_api_key_prod_991823

# Observability - Logging
LOG_LEVEL=info

# Observability - OpenTelemetry Tracing (otel-setup.ts)
ENABLE_OTEL=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317

# Security Configurations
ENCRYPTION_KEY=aes_256_gcm_encryption_key_must_be_32_bytes_9921
COOKIE_SECRET=http_only_cookie_signing_secret_key_prod_991823
# Required - connector credentials and webhook secrets are encrypted at rest
# under this key (AES-256-GCM). The app refuses to start without it.
CONNECTOR_ENCRYPTION_KEY=connector_credential_encryption_key_prod_991823
# Required - signs widget visitor session JWTs. The app refuses to start
# without it.
WIDGET_JWT_SECRET=widget_visitor_session_jwt_signing_secret_prod_991823
# Admin module secrets - admin-webhook.service.ts / admin-api-key.service.ts
# fall back to insecure hardcoded defaults when unset.
ADMIN_WEBHOOK_ENCRYPTION_KEY=admin_webhook_encryption_key_prod_991823
ADMIN_API_KEY_HASH_SECRET=admin_api_key_hash_secret_prod_991823

# Rate limiter (app.module.ts's ThrottlerModule reads these two names).
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# Local filesystem fallback storage (uploads/ served by main.ts)
UPLOADS_DIR=uploads

# Database connection pool / query tuning (db.ts) - sane defaults if unset,
# listed here so they're visible/tunable without a code change.
DATABASE_REPLICA_URL=
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONN_TIMEOUT=2000
DB_STATEMENT_TIMEOUT_MS=30000
DB_QUERY_LOGGING=false
SLOW_QUERY_THRESHOLD_MS=100

# Inbox search cache TTL in seconds (inbox-search.service.ts)
INBOX_SEARCH_CACHE_TTL=300

# SLA business-hours / holiday calendar (business-hours.ts) - SLA_HOLIDAYS is
# a comma-separated list of YYYY-MM-DD dates.
SLA_HOLIDAYS=
SLA_BUSINESS_START_HOUR=9
SLA_BUSINESS_END_HOUR=17

# Ticket AI escalation thresholds (ticket-escalation.service.ts)
TICKET_AI_CONFIDENCE_THRESHOLD=0.7
TICKET_NEGATIVE_SENTIMENT_THRESHOLD=-0.5

# Connector circuit breaker tuning (circuit-breaker.ts)
CONNECTOR_CB_FAILURE_THRESHOLD=5
CONNECTOR_CB_SUCCESS_THRESHOLD=2
CONNECTOR_CB_RESET_TIMEOUT_MS=30000
