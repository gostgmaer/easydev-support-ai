# ==============================================================================
# EASYDEV SUPPORT AI - PRODUCTION ENVIRONMENT TEMPLATE (.env.production.example)
# ==============================================================================

# Core Application Settings
NODE_ENV=production
PORT=3100
APP_NAME=easydev-support-ai-production
APP_VERSION=1.0.0
API_PREFIX=/v1

# Database Configuration (Production Postgres)
# DB_PASSWORD must match docker-compose.production.yml's POSTGRES_PASSWORD
# (also sourced from DB_PASSWORD) - they were previously two copies of the
# same hardcoded literal; keep them as one value, not two.
DB_PASSWORD=CHANGE_ME_strong_password_here
DATABASE_URL=postgresql://support_ai_prod:CHANGE_ME_strong_password_here@postgres:5432/easydev_support_ai_prod?sslmode=disable
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=easydev_support_ai_prod
POSTGRES_USER=support_ai_prod
POSTGRES_PASSWORD=prod_db_pass_extremely_secure_991823

# Redis Cache & Queue Configuration (Production Redis)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_auth_pass_extremely_secure_991283
REDIS_DB=0

# IAM Service Integration
IAM_SERVICE_URL=https://iam.easydev.in
IAM_SERVICE_INTERNAL_URL=http://host.docker.internal:3001
# IAM service API key (usage-limit.service.ts) - separate from
# IAM_SERVICE_URL/IAM_SERVICE_INTERNAL_URL above.
IAM_SERVICE_API_KEY=production_iam_service_api_key_991823

# AI Platform Integration
EASYDEV_AI_URL=https://ai.easydev.in
EASYDEV_AI_API_KEY=production_ai_platform_api_key_991823

# Notification Service Integration
NOTIFICATION_SERVICE_URL=https://notification.easydev.in
NOTIFICATION_SERVICE_API_KEY=production_notification_api_key_991823

# Payment Service Integration
PAYMENT_SERVICE_URL=https://payment.easydev.in
PAYMENT_SERVICE_API_KEY=production_payment_api_key_991823

# File Upload Service Integration
FILE_UPLOAD_SERVICE_URL=https://upload.easydev.in
FILE_UPLOAD_SERVICE_HEALTH_URL=https://upload.easydev.in/health
# Shared gateway HMAC secret - must match the same value configured on the
# file-upload-service / payment-microservice side (PaymentClient signs
# outbound requests with this; their GatewayHmacGuard verifies with it).
FILE_UPLOAD_HMAC_SECRET=production_file_upload_hmac_secret_991823
FILE_UPLOAD_SERVICE_API_KEY=production_file_upload_service_api_key_991823

# Logging Level
LOG_LEVEL=info

# OpenTelemetry Configuration (otel-setup.ts)
ENABLE_OTEL=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317

# Client & Channel Domains
CORS_ALLOWED_ORIGINS=https://admin.easydev.in,https://app.easydev.in,https://widget.easydev.in,https://help.easydev.in
API_PUBLIC_URL=https://api.easydev.in
API_BASE_URL=https://api.easydev.in
PORTAL_URL=https://admin.easydev.in
WIDGET_SURVEY_BASE_URL=https://widget.easydev.in

# Security Configurations (AES-256 GCM Key must be 32 bytes hex/text)
ENCRYPTION_KEY=production_aes_encryption_key_32bytes_9921
COOKIE_SECRET=production_cookie_signing_secret_key_991823
# Required - connector credentials/webhook secrets encrypted at rest under
# this key; the app refuses to start without it.
CONNECTOR_ENCRYPTION_KEY=production_connector_encryption_key_991823
# Required - signs widget visitor session JWTs; the app refuses to start
# without it.
WIDGET_JWT_SECRET=production_widget_jwt_secret_991823
# Admin module secrets - fall back to insecure hardcoded defaults when unset.
ADMIN_WEBHOOK_ENCRYPTION_KEY=production_admin_webhook_encryption_key_991823
ADMIN_API_KEY_HASH_SECRET=production_admin_api_key_hash_secret_991823

# Rate limiter (app.module.ts's ThrottlerModule reads these two names).
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100


# Local filesystem fallback storage (uploads/ served by main.ts)
UPLOADS_DIR=uploads

# Database connection pool / query tuning (db.ts) - sane defaults if unset.
DATABASE_REPLICA_URL=
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONN_TIMEOUT=2000
DB_STATEMENT_TIMEOUT_MS=30000
DB_QUERY_LOGGING=false
SLOW_QUERY_THRESHOLD_MS=100

# Inbox search cache TTL in seconds (inbox-search.service.ts)
INBOX_SEARCH_CACHE_TTL=300

# SLA business-hours / holiday calendar (business-hours.ts)
SLA_HOLIDAYS=
SLA_BUSINESS_START_HOUR=9
SLA_BUSINESS_END_HOUR=17

# Ticket AI escalation thresholds (ticket-escalation.service.ts)
TICKET_AI_CONFIDENCE_THRESHOLD=0.7
TICKET_NEGATIVE_SENTIMENT_THRESHOLD=-0.5

# Connector circuit breaker tuning (circuit-breaker.ts)
CONNECTOR_CB_FAILURE_THRESHOLD=5
CONNECTOR_CB_SUCCESS_THRESHOLD=2
CONNECTOR_CB_RESET_TIMEOUT_MS=30000
