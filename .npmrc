# Allow native-binding packages to run their postinstall build scripts.
# This mirrors the pnpm.onlyBuiltDependencies array in package.json and is
# required for pnpm 10 to accept these packages without ERR_PNPM_IGNORED_BUILDS.
onlyBuiltDependencies[]=@scarf/scarf
onlyBuiltDependencies[]=esbuild
onlyBuiltDependencies[]=msgpackr-extract
onlyBuiltDependencies[]=unrs-resolver

# Use hoisted node_modules layout so all transitive dependencies are accessible
# at node_modules root. Required because NestJS compiled output imports express
# and other transitive deps that pnpm isolates in its virtual store by default.
node-linker=hoisted

# Do NOT auto-install peer dependencies. The workspace libraries (@easydev/*)
# declare @nestjs/common and @nestjs/core as peerDependencies so they share the
# host app's single Nest runtime. With auto-install-peers (the pnpm default),
# pnpm would mint a SECOND peer-resolved @nestjs/core for the libraries (whose
# peer graph lacks platform-express/websockets), producing two ModulesContainer
# classes and breaking DI (DiscoveryService cannot resolve ModulesContainer).
# Under the hoisted layout above, disabling this makes the libraries resolve the
# single root @nestjs/core instead.
auto-install-peers=false
