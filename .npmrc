# Allow native-binding packages to run their postinstall build scripts.
# This mirrors the pnpm.onlyBuiltDependencies array in package.json and is
# required for pnpm 10 to accept these packages without ERR_PNPM_IGNORED_BUILDS.
onlyBuiltDependencies[]=@scarf/scarf
onlyBuiltDependencies[]=esbuild
onlyBuiltDependencies[]=msgpackr-extract
onlyBuiltDependencies[]=unrs-resolver
