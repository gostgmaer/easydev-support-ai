# --- BUILD STAGE ---
FROM node:22-alpine AS builder

WORKDIR /usr/src/app

# Use corepack to install pnpm — avoids npm SSL issues on Alpine
RUN corepack enable && corepack prepare pnpm@10.15.0 --activate

# Copy manifest + lockfile first for better layer caching
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.json tsconfig.build.json ./
# .npmrc must be present before `pnpm install` so onlyBuiltDependencies is respected
COPY .npmrc ./
COPY packages ./packages
COPY src ./src

RUN pnpm install --frozen-lockfile
RUN pnpm run build:packages
RUN pnpm run build

# --- RUN STAGE ---
FROM node:22-alpine AS runner

WORKDIR /usr/src/app

# Copy full node_modules from builder — avoids pnpm workspace prod-resolution
# issues where transitive deps of workspace packages go missing.
COPY --from=builder /usr/src/app/node_modules ./node_modules
COPY --from=builder /usr/src/app/package.json ./
COPY --from=builder /usr/src/app/pnpm-workspace.yaml ./
COPY --from=builder /usr/src/app/dist ./dist
COPY --from=builder /usr/src/app/packages ./packages
COPY scripts/health-check.js ./dist/health-check.js

# drizzle-kit is a devDependency of packages/database (CLI-only, run in CI /
# manually via `drizzle-kit generate|migrate` — never imported by app source)
# but the hoisted node_modules layout above pulls it in wholesale. It bundles
# its own compiled esbuild binary with several HIGH/CRITICAL Go stdlib CVEs,
# which fails the Trivy scan below. Self-contained directory, safe to strip.
# esbuild/tsx are separate hoisted top-level copies of the same devDependency
# chain (drizzle-kit -> @esbuild-kit/esm-loader / tsx -> its own vendored
# esbuild) - `pnpm why esbuild` confirms every instance traces only to
# drizzle-kit, so they leak the same CVEs even after drizzle-kit itself is
# gone and need stripping too.
RUN rm -rf node_modules/drizzle-kit node_modules/esbuild node_modules/@esbuild node_modules/tsx

# uploads/ is created and served (main.ts useStaticAssets) and written to at
# runtime (widget attachment uploads) by the unprivileged node user below -
# without this it's root-owned and every write fails with EACCES.
RUN mkdir -p uploads && chown -R node:node uploads

USER node

EXPOSE 3100
ENV NODE_ENV=production
ENV PORT=3100

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 CMD [ "node", "dist/health-check.js" ]

CMD ["node", "dist/src/main.js"]
