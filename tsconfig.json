{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@easydev/shared-kernel": ["packages/shared-kernel/src/index.ts"],
      "@easydev/database": ["packages/database/src/index.ts"],
      "@easydev/shared-events": ["packages/shared-events/src/index.ts"],
      "@easydev/shared-contracts": ["packages/shared-contracts/src/index.ts"],
      "@easydev/shared-clients": ["packages/shared-clients/src/index.ts"],
      "@easydev/shared-queues": ["packages/shared-queues/src/index.ts"],
      "@easydev/shared-testing": ["packages/shared-testing/src/index.ts"]
    }
  }
}
