# ==============================================================================
# EASYDEV SUPPORT AI - STAGING ENVIRONMENT TEMPLATE (.env.staging.example)
# ==============================================================================

# Core Application Settings
NODE_ENV=production
PORT=3100
APP_NAME=easydev-support-ai-staging
APP_VERSION=1.0.0
API_PREFIX=/v1

# Database Configuration (Staging Postgres)
DATABASE_URL=postgresql://support_ai_staging:staging_password_secure_99@postgres:5432/easydev_support_ai_staging?sslmode=disable
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=easydev_support_ai_staging
POSTGRES_USER=support_ai_staging
POSTGRES_PASSWORD=staging_password_secure_99

# Redis Cache & Queue Configuration (Staging Redis)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0

# Authentication & Session Management
JWT_SECRET=staging_jwt_access_token_secret_key_extremely_secure_990123
JWT_REFRESH_SECRET=staging_jwt_refresh_token_secret_key_extremely_secure_990123
IAM_SERVICE_URL=https://iam-staging.easydev.in
IAM_SERVICE_INTERNAL_URL=http://host.docker.internal:3001

# AI Platform Integration
AI_PLATFORM_URL=https://ai-staging.easydev.in
AI_PLATFORM_INTERNAL_URL=http://host.docker.internal:3002
AI_PLATFORM_API_KEY=staging_ai_platform_api_key_990123

# Notification Service Integration
NOTIFICATION_SERVICE_URL=https://notification-staging.easydev.in
NOTIFICATION_SERVICE_API_KEY=staging_notification_api_key_990123

# Payment Service Integration
PAYMENT_SERVICE_URL=https://payment-staging.easydev.in
PAYMENT_SERVICE_API_KEY=staging_payment_api_key_990123

# File Upload Service Integration
FILE_UPLOAD_SERVICE_URL=https://upload-staging.easydev.in
FILE_UPLOAD_SERVICE_HEALTH_URL=https://upload-staging.easydev.in/health
FILE_UPLOAD_HMAC_SECRET=staging_file_upload_hmac_secret_990123
FILE_UPLOAD_SERVICE_API_KEY=staging_file_upload_service_api_key_990123

# IAM service API key (usage-limit.service.ts) - separate from
# IAM_SERVICE_URL/IAM_SERVICE_INTERNAL_URL above.
IAM_SERVICE_API_KEY=staging_iam_service_api_key_990123

# BullMQ Queue Settings
BULLMQ_PREFIX=easydev-support-ai-queue-staging

# Observability - Logging
LOG_LEVEL=info

# Observability - OpenTelemetry Tracing - the code (otel-setup.ts) reads
# these two names, not OTEL_ENABLED/OTEL_ENDPOINT below (not read anywhere
# in this app).
ENABLE_OTEL=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_ENABLED=true
OTEL_ENDPOINT=http://tempo:4317

# Observability - Prometheus Metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Client & Channel Domains
WIDGET_DOMAIN=widget-staging.easydev.in
WIDGET_PUBLIC_URL=https://widget-staging.easydev.in
ADMIN_PORTAL_URL=https://admin-staging.easydev.in
PUBLIC_API_URL=https://api-staging.easydev.in
# Same value as PUBLIC_API_URL/PORTAL_URL above under a different name - the
# code reads these three specific names (different call sites, never
# consolidated), so all three must be kept in sync by hand.
API_PUBLIC_URL=https://api-staging.easydev.in
API_BASE_URL=https://api-staging.easydev.in
PORTAL_URL=https://admin-staging.easydev.in
WIDGET_SURVEY_BASE_URL=https://widget-staging.easydev.in

# CORS - origins allowed to call this API directly.
CORS_ALLOWED_ORIGINS=https://admin-staging.easydev.in,https://app-staging.easydev.in,https://widget-staging.easydev.in,https://help-staging.easydev.in

# Security Configurations
ENCRYPTION_KEY=staging_aes_encryption_key_32bytes_9921
WEBHOOK_SECRET=staging_webhook_secret_key_990123
COOKIE_SECRET=staging_cookie_signing_secret_key_990123
# Required - connector credentials/webhook secrets encrypted at rest under
# this key; the app refuses to start without it.
CONNECTOR_ENCRYPTION_KEY=staging_connector_encryption_key_990123
# Required - signs widget visitor session JWTs; the app refuses to start
# without it.
WIDGET_JWT_SECRET=staging_widget_jwt_secret_990123
# Admin module secrets - fall back to insecure hardcoded defaults when unset.
ADMIN_WEBHOOK_ENCRYPTION_KEY=staging_admin_webhook_encryption_key_990123
ADMIN_API_KEY_HASH_SECRET=staging_admin_api_key_hash_secret_990123

# Global Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=200

# Email Integration (SMTP Staging)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=staging_smtp_password_secret_key_990123
SMTP_FROM=support-staging@easydev.in

# Object Storage Configuration (AWS S3 Staging)
STORAGE_PROVIDER=s3
STORAGE_BUCKET=easydev-support-ai-backups-staging
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=aws_iam_access_key_id_staging_990123
STORAGE_SECRET_KEY=aws_iam_secret_access_key_staging_990123

# Analytics Module Settings
ANALYTICS_RETENTION_DAYS=30

# Backup & Disaster Recovery Configurations
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=7

# Feature Flags
FEATURE_FLAGS_ENABLED=true

# Local filesystem fallback storage (uploads/ served by main.ts)
UPLOADS_DIR=uploads

# Database connection pool / query tuning (db.ts) - sane defaults if unset.
DATABASE_REPLICA_URL=
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONN_TIMEOUT=2000
DB_STATEMENT_TIMEOUT_MS=30000
DB_QUERY_LOGGING=false
SLOW_QUERY_THRESHOLD_MS=100

# Inbox search cache TTL in seconds (inbox-search.service.ts)
INBOX_SEARCH_CACHE_TTL=300

# SLA business-hours / holiday calendar (business-hours.ts)
SLA_HOLIDAYS=
SLA_BUSINESS_START_HOUR=9
SLA_BUSINESS_END_HOUR=17

# Ticket AI escalation thresholds (ticket-escalation.service.ts)
TICKET_AI_CONFIDENCE_THRESHOLD=0.7
TICKET_NEGATIVE_SENTIMENT_THRESHOLD=-0.5

# Connector circuit breaker tuning (circuit-breaker.ts)
CONNECTOR_CB_FAILURE_THRESHOLD=5
CONNECTOR_CB_SUCCESS_THRESHOLD=2
CONNECTOR_CB_RESET_TIMEOUT_MS=30000
