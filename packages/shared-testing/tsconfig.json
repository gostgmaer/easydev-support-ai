{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "ES2022",
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "@easydev/shared-kernel": ["../shared-kernel/src/index.ts"],
      "@easydev/database": ["../database/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
