# ==============================================================================
# EASYDEV SUPPORT AI - LOCAL DEVELOPMENT TEMPLATE (.env.local.example)
# ==============================================================================

# Core Application Settings
NODE_ENV=development
PORT=3000
APP_NAME=easydev-support-ai-local
APP_VERSION=1.0.0
API_PREFIX=/v1

# Database Configuration (Local Postgres)
# Ports are mapped to 5434 in docker-compose.local.yml for external access
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/easydev_support_ai?sslmode=disable
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_DB=easydev_support_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis Cache & Queue Configuration (Local Redis)
# Redis is mapped to 6381 in docker-compose.local.yml
REDIS_HOST=localhost
REDIS_PORT=6381
REDIS_PASSWORD=""
REDIS_DB=0

# Authentication & Session Management
JWT_SECRET=local_jwt_access_token_secret_key_extremely_secure_190283
JWT_REFRESH_SECRET=local_jwt_refresh_token_secret_key_extremely_secure_190283
IAM_SERVICE_URL=http://localhost:3001
IAM_SERVICE_INTERNAL_URL=http://localhost:3001

# AI Platform Integration
AI_PLATFORM_URL=http://localhost:3002
AI_PLATFORM_INTERNAL_URL=http://localhost:3002
AI_PLATFORM_API_KEY=local_ai_platform_api_key_190283

# Notification Service Integration
NOTIFICATION_SERVICE_URL=http://localhost:3003
NOTIFICATION_SERVICE_API_KEY=local_notification_api_key_190283

# Payment Service Integration
PAYMENT_SERVICE_URL=http://localhost:3004
PAYMENT_SERVICE_API_KEY=local_payment_api_key_190283

# File Upload Service Integration
FILE_UPLOAD_SERVICE_URL=http://localhost:3006
FILE_UPLOAD_SERVICE_HEALTH_URL=http://localhost:3006/health
FILE_UPLOAD_HMAC_SECRET=local_file_upload_hmac_secret_190283

# BullMQ Queue Settings
BULLMQ_PREFIX=easydev-support-ai-queue-local

# Observability - Logging
LOG_LEVEL=debug

# Observability - OpenTelemetry Tracing (Disabled for local dev)
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4317

# Observability - Prometheus Metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Client & Channel Domains
WIDGET_DOMAIN=localhost
WIDGET_PUBLIC_URL=http://localhost:3000
ADMIN_PORTAL_URL=http://localhost:3005
PUBLIC_API_URL=http://localhost:3000

# Security Configurations
ENCRYPTION_KEY=local_aes_encryption_key_32bytes_9921
WEBHOOK_SECRET=local_webhook_secret_key_190283
COOKIE_SECRET=local_cookie_signing_secret_key_190283

# Global Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# Email Integration (SMTP Mock)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=support@easydev.local

# Object Storage Configuration (Local File Fallback)
STORAGE_PROVIDER=local
STORAGE_BUCKET=easydev-local-storage
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""

# Analytics Module Settings
ANALYTICS_RETENTION_DAYS=7

# Backup & Disaster Recovery Configurations
BACKUP_ENABLED=false
BACKUP_RETENTION_DAYS=2

# Feature Flags
FEATURE_FLAGS_ENABLED=true
