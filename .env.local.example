# ==============================================================================
# EASYDEV SUPPORT AI - LOCAL DEVELOPMENT TEMPLATE (.env.local.example)
# ==============================================================================

# Core Application Settings
NODE_ENV=development
PORT=3100
APP_NAME=easydev-support-ai-local
APP_VERSION=1.0.0
API_PREFIX=/v1

# Database Configuration (Local Postgres)
# Ports are mapped to 5434 in docker-compose.local.yml for external access
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/easydev_support_ai?sslmode=disable
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_DB=easydev_support_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis Cache & Queue Configuration (Local Redis)
# Redis is mapped to 6381 in docker-compose.local.yml
REDIS_HOST=localhost
REDIS_PORT=6381
REDIS_PASSWORD=""
REDIS_DB=0

# IAM Service Integration
IAM_SERVICE_URL=http://localhost:3001
IAM_SERVICE_INTERNAL_URL=http://localhost:3001
# IAM service API key (usage-limit.service.ts) - separate from
# IAM_SERVICE_URL/IAM_SERVICE_INTERNAL_URL above.
IAM_SERVICE_API_KEY=local_iam_service_api_key_190283

# AI Platform Integration
EASYDEV_AI_URL=http://localhost:3002
EASYDEV_AI_API_KEY=local_ai_platform_api_key_190283

# Notification Service Integration
NOTIFICATION_SERVICE_URL=http://localhost:3003
NOTIFICATION_SERVICE_API_KEY=local_notification_api_key_190283

# Payment Service Integration
PAYMENT_SERVICE_URL=http://localhost:3004
PAYMENT_SERVICE_API_KEY=local_payment_api_key_190283

# File Upload Service Integration
FILE_UPLOAD_SERVICE_URL=http://localhost:3006
FILE_UPLOAD_SERVICE_HEALTH_URL=http://localhost:3006/health
# Shared gateway HMAC secret - must match the same value configured on the
# file-upload-service / payment-microservice side (PaymentClient signs
# outbound requests with this; their GatewayHmacGuard verifies with it).
FILE_UPLOAD_HMAC_SECRET=local_file_upload_hmac_secret_190283
FILE_UPLOAD_SERVICE_API_KEY=local_file_upload_service_api_key_190283

# Observability - Logging
LOG_LEVEL=debug

# Observability - OpenTelemetry Tracing (Disabled for local dev)
ENABLE_OTEL=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Client & Channel Domains
CORS_ALLOWED_ORIGINS=http://localhost:3011,http://localhost:3012,http://localhost:3013,http://localhost:3014
API_PUBLIC_URL=http://localhost:3100
API_BASE_URL=http://localhost:3100
PORTAL_URL=http://localhost:3011
WIDGET_SURVEY_BASE_URL=http://localhost:3013

# Required at boot (credential-manager.ts / widget-session.service.ts throw
# without these, regardless of NODE_ENV).
CONNECTOR_ENCRYPTION_KEY=local_connector_encryption_key_190283
WIDGET_JWT_SECRET=local_widget_jwt_secret_190283

# Admin module secrets - admin-webhook.service.ts / admin-api-key.service.ts
# fall back to insecure hardcoded defaults when unset.
ADMIN_WEBHOOK_ENCRYPTION_KEY=local_admin_webhook_encryption_key_190283
ADMIN_API_KEY_HASH_SECRET=local_admin_api_key_hash_secret_190283

# Security Configurations
ENCRYPTION_KEY=local_aes_encryption_key_32bytes_9921
COOKIE_SECRET=local_cookie_signing_secret_key_190283

# Rate limiter (app.module.ts's ThrottlerModule reads these two names).
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=1000


# Local filesystem fallback storage (uploads/ served by main.ts)
UPLOADS_DIR=uploads

# Database connection pool / query tuning (db.ts) - sane defaults if unset.
DATABASE_REPLICA_URL=
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONN_TIMEOUT=2000
DB_STATEMENT_TIMEOUT_MS=30000
DB_QUERY_LOGGING=false
SLOW_QUERY_THRESHOLD_MS=100

# Inbox search cache TTL in seconds (inbox-search.service.ts)
INBOX_SEARCH_CACHE_TTL=300

# SLA business-hours / holiday calendar (business-hours.ts)
SLA_HOLIDAYS=
SLA_BUSINESS_START_HOUR=9
SLA_BUSINESS_END_HOUR=17

# Ticket AI escalation thresholds (ticket-escalation.service.ts)
TICKET_AI_CONFIDENCE_THRESHOLD=0.7
TICKET_NEGATIVE_SENTIMENT_THRESHOLD=-0.5

# Connector circuit breaker tuning (circuit-breaker.ts)
CONNECTOR_CB_FAILURE_THRESHOLD=5
CONNECTOR_CB_SUCCESS_THRESHOLD=2
CONNECTOR_CB_RESET_TIMEOUT_MS=30000
