NODE_ENV=development
PORT=3100
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=easydev_support_ai
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/easydev_support_ai?sslmode=disable
REDIS_HOST=redis
REDIS_PORT=6379
ENABLE_OTEL=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
ENCRYPTION_KEY=dev-encryption-key-for-easydev-32bytes

# Rate limiter (app.module.ts's ThrottlerModule reads these two names, not
# RATE_LIMIT_WINDOW_MS/RATE_LIMIT_MAX_REQUESTS).
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# Required at boot (credential-manager.ts / widget-session.service.ts throw
# without these, regardless of NODE_ENV).
CONNECTOR_ENCRYPTION_KEY=dev-connector-encryption-key-123456
WIDGET_JWT_SECRET=dev-widget-jwt-secret-123456

# Required at boot when NODE_ENV=production (validate-env.ts) - kept here
# too since deploy.sh/rollback.sh pass this same file's vars regardless of
# NODE_ENV, and several services (AI platform client, IAM gateway) need
# real values to function even outside that boot check.
EASYDEV_AI_URL=http://host.docker.internal:8000
EASYDEV_AI_API_KEY=dev-ai-platform-api-key-123456
EASYDEV_IAM_URL=http://host.docker.internal:3304
IAM_SERVICE_URL=http://host.docker.internal:3304
IAM_SERVICE_INTERNAL_URL=http://host.docker.internal:3304
IAM_SERVICE_API_KEY=dev-iam-service-api-key-123456

CORS_ALLOWED_ORIGINS=http://localhost:3011,http://localhost:3012,http://localhost:3013,http://localhost:3014
API_PUBLIC_URL=http://localhost:3100
API_BASE_URL=http://localhost:3100
PORTAL_URL=http://localhost:3011
WIDGET_SURVEY_BASE_URL=http://localhost:3013

ADMIN_WEBHOOK_ENCRYPTION_KEY=dev-admin-webhook-encryption-key-123456
ADMIN_API_KEY_HASH_SECRET=dev-admin-api-key-hash-secret-123456

FILE_UPLOAD_SERVICE_URL=http://host.docker.internal:8081
FILE_UPLOAD_SERVICE_API_KEY=dev-file-upload-service-api-key-123456
# Shared gateway HMAC secret - must match the same value configured on the
# file-upload-service / payment-microservice side (PaymentClient signs
# outbound requests with this; their GatewayHmacGuard verifies with it).
FILE_UPLOAD_HMAC_SECRET=dev-file-upload-hmac-secret-123456

PAYMENT_SERVICE_URL=http://host.docker.internal:3302
PAYMENT_SERVICE_API_KEY=dev-payment-service-api-key-123456

NOTIFICATION_SERVICE_URL=http://host.docker.internal:8082
NOTIFICATION_SERVICE_API_KEY=dev-notification-service-api-key-123456
UPLOADS_DIR=uploads
