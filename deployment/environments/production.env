NODE_ENV=production
PORT=3100
DB_HOST=prod-postgres.easydev.internal
DB_PORT=5432
DB_USER=support_ai_prod
DB_PASSWORD=prod_db_pass_extremely_secure_991823
DB_NAME=easydev_support_ai_prod
DATABASE_URL=postgresql://support_ai_prod:prod_db_pass_extremely_secure_991823@prod-postgres.easydev.internal:5432/easydev_support_ai_prod?sslmode=disable
REDIS_HOST=prod-redis.easydev.internal
REDIS_PORT=6379
ENABLE_OTEL=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
LOKI_URL=http://loki:3100/loki/api/v1/push
ENCRYPTION_KEY=prod-encryption-key-for-easydev-32bytes-mustbe32

# Rate limiter (app.module.ts's ThrottlerModule reads these two names, not
# RATE_LIMIT_WINDOW_MS/RATE_LIMIT_MAX_REQUESTS).
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# Required at boot when NODE_ENV=production (validate-env.ts) - missing
# here previously meant deploy.sh/rollback.sh would boot a container that
# immediately exits 1.
CONNECTOR_ENCRYPTION_KEY=production_connector_encryption_key_991823
WIDGET_JWT_SECRET=production_widget_jwt_secret_991823
EASYDEV_AI_URL=https://ai.easydev.in
EASYDEV_AI_API_KEY=production_ai_platform_api_key_991823
EASYDEV_IAM_URL=https://iam.easydev.in
IAM_SERVICE_URL=https://iam.easydev.in
IAM_SERVICE_INTERNAL_URL=http://host.docker.internal:3001
IAM_SERVICE_API_KEY=production_iam_service_api_key_991823

ADMIN_WEBHOOK_ENCRYPTION_KEY=production_admin_webhook_encryption_key_991823
ADMIN_API_KEY_HASH_SECRET=production_admin_api_key_hash_secret_991823

FILE_UPLOAD_SERVICE_URL=https://upload.easydev.in
FILE_UPLOAD_SERVICE_API_KEY=production_file_upload_service_api_key_991823
# Shared gateway HMAC secret - must match the same value configured on the
# file-upload-service / payment-microservice side (PaymentClient signs
# outbound requests with this; their GatewayHmacGuard verifies with it).
FILE_UPLOAD_HMAC_SECRET=production_file_upload_hmac_secret_991823

PAYMENT_SERVICE_URL=https://payment.easydev.in
PAYMENT_SERVICE_API_KEY=production_payment_service_api_key_991823
# Optional - IAM client_credentials for payment-microservice (preferred over
# the legacy API key above). Leave unset until this app is registered as an
# IAM application (POST /apps on the IAM service) and issued real
# credentials - PaymentClient transparently keeps using the API key above
# until then.
PAYMENT_IAM_CLIENT_ID=
PAYMENT_IAM_CLIENT_SECRET=
PAYMENT_IAM_SCOPES=payment:read payment:write

NOTIFICATION_SERVICE_URL=https://notification.easydev.in
NOTIFICATION_SERVICE_API_KEY=production_notification_service_api_key_991823

CORS_ALLOWED_ORIGINS=https://admin.easydev.in,https://app.easydev.in,https://widget.easydev.in,https://help.easydev.in
API_PUBLIC_URL=https://api.easydev.in
API_BASE_URL=https://api.easydev.in
PORTAL_URL=https://admin.easydev.in
WIDGET_SURVEY_BASE_URL=https://widget.easydev.in
UPLOADS_DIR=uploads
