NODE_ENV=production
PORT=3100
DB_HOST=prod-postgres.easydev.internal
DB_PORT=5432
DB_USER=support_ai_prod
DB_PASSWORD=prod_db_pass_extremely_secure_991823
DB_NAME=easydev_support_ai_prod
