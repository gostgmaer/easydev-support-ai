# Core Platform
NODE_ENV=production
PORT=3100

# Database Settings
DB_HOST=postgres
DB_PORT=5432
DB_USER=support_ai_prod
DB_PASSWORD=YOUR_DB_PASSWORD
DB_NAME=easydev_support_ai_prod
DATABASE_URL=postgresql://support_ai_prod:YOUR_DB_PASSWORD@postgres:5432/easydev_support_ai_prod?sslmode=disable

# Redis / Queue Settings
REDIS_HOST=redis
REDIS_PORT=6379

# Tracing & Monitoring (OpenTelemetry & Grafana Loki)
ENABLE_OTEL=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
LOKI_URL=http://loki:3100/loki/api/v1/push

# Rate limiter (app.module.ts's ThrottlerModule reads these two names, not
# RATE_LIMIT_WINDOW_MS/RATE_LIMIT_MAX_REQUESTS).
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# Integrations
EASYDEV_IAM_URL=http://iam-service.easydev.internal:3001
IAM_SERVICE_URL=http://iam-service.easydev.internal:3001
IAM_SERVICE_INTERNAL_URL=http://iam-service.easydev.internal:3001
IAM_SERVICE_API_KEY=YOUR_IAM_SERVICE_API_KEY
EASYDEV_AI_URL=http://ai-service.easydev.internal:3002
EASYDEV_AI_API_KEY=YOUR_AI_PLATFORM_API_KEY
FILE_UPLOAD_SERVICE_URL=http://file-upload-service.easydev.internal:8080
FILE_UPLOAD_SERVICE_API_KEY=YOUR_FILE_UPLOAD_SERVICE_API_KEY
# Shared gateway HMAC secret - must match the same value configured on the
# file-upload-service / payment-microservice side (PaymentClient signs
# outbound requests with this; their GatewayHmacGuard verifies with it).
FILE_UPLOAD_HMAC_SECRET=YOUR_FILE_UPLOAD_HMAC_SECRET
PAYMENT_SERVICE_URL=http://payment-service.easydev.internal:3302
PAYMENT_SERVICE_API_KEY=YOUR_PAYMENT_SERVICE_API_KEY
# Optional - IAM client_credentials for payment-microservice (preferred over
# the legacy API key above). Leave unset until this app is registered as an
# IAM application (POST /apps on the IAM service) and issued real
# credentials - PaymentClient transparently keeps using the API key above
# until then.
PAYMENT_IAM_CLIENT_ID=
PAYMENT_IAM_CLIENT_SECRET=
PAYMENT_IAM_SCOPES=payment:read payment:write
NOTIFICATION_SERVICE_URL=http://notification-service.easydev.internal:8082
NOTIFICATION_SERVICE_API_KEY=YOUR_NOTIFICATION_SERVICE_API_KEY

# Secrets (Rotatable keys)
ENCRYPTION_KEY=YOUR_32_BYTE_ENCRYPTION_KEY
# Required at boot regardless of NODE_ENV (credential-manager.ts /
# widget-session.service.ts throw without these).
CONNECTOR_ENCRYPTION_KEY=YOUR_CONNECTOR_ENCRYPTION_KEY
WIDGET_JWT_SECRET=YOUR_WIDGET_JWT_SECRET
ADMIN_WEBHOOK_ENCRYPTION_KEY=YOUR_ADMIN_WEBHOOK_ENCRYPTION_KEY
ADMIN_API_KEY_HASH_SECRET=YOUR_ADMIN_API_KEY_HASH_SECRET

# Public URLs (CORS / absolute-URL building) - replace with your real domains
CORS_ALLOWED_ORIGINS=https://admin.example.com,https://app.example.com,https://widget.example.com,https://help.example.com
API_PUBLIC_URL=https://api.example.com
API_BASE_URL=https://api.example.com
PORTAL_URL=https://admin.example.com
WIDGET_SURVEY_BASE_URL=https://widget.example.com
UPLOADS_DIR=uploads
